{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flow-memory.local/schemas/FlowCard.schema.json",
  "title": "Flow Memory System Flow Card",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "goal",
    "status",
    "entry_points",
    "triggers",
    "steps",
    "anchor_nodes",
    "anchor_files"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/flowId"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated"
      ]
    },
    "entry_points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/uiOrRouteNodeId"
      }
    },
    "triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+_[a-z0-9_]+:\\s*[a-z0-9_.:-]+$"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "persistence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/persistenceDefinition"
      }
    },
    "return_paths": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/returnPath"
      }
    },
    "anchor_nodes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/nodeId"
      }
    },
    "anchor_files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "watch_points": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "common_failures": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "related_flows": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/flowId"
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "flowId": {
      "type": "string",
      "pattern": "^flow\\.[a-z0-9_]+(?:\\.[a-z0-9_]+)?$"
    },
    "nodeId": {
      "type": "string",
      "pattern": "^(page|route|ui|action|entity|state|persistence|service|component|api|function)[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
    },
    "uiOrRouteNodeId": {
      "type": "string",
      "pattern": "^(ui|route)[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
    },
    "stringOrStringArray": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "action"
      ],
      "properties": {
        "step_id": {
          "type": "string",
          "pattern": "^s[1-9][0-9]*$"
        },
        "action": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "from": {
          "$ref": "#/$defs/nodeId"
        },
        "to": {
          "$ref": "#/$defs/nodeId"
        },
        "actor": {
          "$ref": "#/$defs/nodeId"
        },
        "target": {
          "$ref": "#/$defs/nodeId"
        },
        "input": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "output": {
          "$ref": "#/$defs/stringOrStringArray"
        },
        "store": {
          "type": "string",
          "pattern": "^persistence[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
        },
        "service": {
          "type": "string",
          "pattern": "^(service|api)[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "persistenceDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "required"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^persistence[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
        },
        "type": {
          "type": "string",
          "enum": [
            "local_storage",
            "session_storage",
            "memory",
            "database",
            "file",
            "api_remote"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "returnPath": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "$ref": "#/$defs/nodeId"
        },
        "to": {
          "$ref": "#/$defs/nodeId"
        },
        "trigger": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
