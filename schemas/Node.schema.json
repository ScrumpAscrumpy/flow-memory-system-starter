{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flow-memory.local/schemas/Node.schema.json",
  "title": "Flow Memory System Node",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "type",
    "files"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/nodeId"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "page",
        "route",
        "ui",
        "action",
        "entity",
        "state",
        "persistence",
        "service",
        "component",
        "api",
        "function"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "functions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "owned_by_flows": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/flowId"
      }
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "change_rules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "flowId": {
      "type": "string",
      "pattern": "^flow\\.[a-z0-9_]+(?:\\.[a-z0-9_]+)?$"
    },
    "nodeId": {
      "type": "string",
      "pattern": "^(page|route|ui|action|entity|state|persistence|service|component|api|function)[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "page"
          }
        }
      },
      "then": {
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^page[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "route"
          }
        }
      },
      "then": {
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^route[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "ui"
          }
        }
      },
      "then": {
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ui[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "action"
          }
        }
      },
      "then": {
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^action[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "entity"
          }
        }
      },
      "then": {
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^entity[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "state"
          }
        }
      },
      "then": {
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^state[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "persistence"
          }
        }
      },
      "then": {
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^persistence[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "service"
          }
        }
      },
      "then": {
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^service[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "component"
          }
        }
      },
      "then": {
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^component[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "api"
          }
        }
      },
      "then": {
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^api[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "function"
          }
        }
      },
      "then": {
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^function[.:][a-z0-9_]+(?:[.:][a-z0-9_]+)*$"
          }
        }
      }
    }
  ]
}
